{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentplane.dev/schemas/recipe-manifest.schema.json",
  "title": "agentplane recipe manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "kind", "id", "version", "name", "summary"],
  "anyOf": [
    { "required": ["prompts"] },
    { "required": ["scenarios"] },
    { "required": ["prompt_modules"] },
    { "required": ["prompt_mutation_sets"] }
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1", "2"] },
    "kind": { "type": "string", "const": "project_overlay" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "name": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 200 },
    "description": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "compatibility": { "$ref": "#/$defs/compatibility" },
    "requires": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "conflicts": {
      "type": "array",
      "items": { "$ref": "#/$defs/conflict" }
    },
    "homepage": { "type": "string", "minLength": 1 },
    "repository": { "type": "string", "minLength": 1 },
    "license": { "type": "string", "minLength": 1 },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "category": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "min_agentplane_version": { "type": "string", "minLength": 1 },
    "maintainers": { "type": "array", "items": { "type": "string" } },
    "prompts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/prompt" }
    },
    "validators": {
      "type": "array",
      "items": { "$ref": "#/$defs/validator" }
    },
    "templates": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/skill" }
    },
    "agents": {
      "type": "array",
      "items": { "$ref": "#/$defs/agent" }
    },
    "tools": {
      "type": "array",
      "items": { "$ref": "#/$defs/tool" }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scenario" }
    },
    "prompt_modules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/prompt_module" }
    },
    "prompt_mutation_sets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/prompt_mutation_set" }
    }
  },
  "$defs": {
    "compatibility": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "min_agentplane_version": { "type": "string", "minLength": 1 },
        "manifest_api_version": { "type": "string", "minLength": 1 },
        "scenario_api_version": { "type": "string", "minLength": 1 },
        "runtime_api_version": { "type": "string", "minLength": 1 },
        "platforms": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "repo_types": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "conflict": {
      "type": "object",
      "additionalProperties": true,
      "required": ["recipe_id", "reason"],
      "properties": {
        "recipe_id": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "when": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "task_kinds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "commands": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "tags_any": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "repo_types": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "prompt": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "surface", "file"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "surface": {
          "type": "string",
          "enum": [
            "planning",
            "execution",
            "coding",
            "debugging",
            "review",
            "verification",
            "docs",
            "finish"
          ]
        },
        "strength": { "type": "string", "enum": ["required", "default", "advisory"] },
        "file": { "type": "string", "minLength": 1 },
        "order": { "type": "number" },
        "when": { "$ref": "#/$defs/when" }
      }
    },
    "validator": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "phase", "kind"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "phase": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["required_evidence", "required_command", "check_script"]
        },
        "required": { "type": "boolean" },
        "evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "command": { "type": "string", "minLength": 1 },
        "runtime": { "type": "string", "enum": ["bash", "node"] },
        "entrypoint": { "type": "string", "minLength": 1 },
        "when": { "$ref": "#/$defs/when" }
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "summary", "file"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 200 },
        "kind": { "type": "string", "minLength": 1 },
        "file": { "type": "string", "minLength": 1 }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "display_name", "role", "summary", "file"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 200 },
        "skills": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "tools": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "file": { "type": "string", "minLength": 1 }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "runtime", "entrypoint", "summary"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "runtime": { "type": "string", "enum": ["node", "bash"] },
        "entrypoint": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 200 },
        "permissions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "timeout_ms": { "type": "number" },
        "cwd_policy": { "type": "string", "minLength": 1 }
      }
    },
    "run_profile": {
      "type": "object",
      "additionalProperties": true,
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "minLength": 1 },
        "sandbox": { "type": "string", "minLength": 1 },
        "writes_artifacts_to": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "name",
        "summary",
        "use_when",
        "required_inputs",
        "outputs",
        "permissions",
        "artifacts",
        "agents_involved",
        "skills_used",
        "tools_used",
        "run_profile",
        "file"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 200 },
        "description": { "type": "string", "minLength": 1 },
        "use_when": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "avoid_when": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "required_inputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "permissions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "artifacts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "agents_involved": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "skills_used": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "tools_used": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "run_profile": { "$ref": "#/$defs/run_profile" },
        "file": { "type": "string", "minLength": 1 }
      }
    },
    "prompt_module": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "summary", "file"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 200 },
        "file": { "type": "string", "minLength": 1 }
      }
    },
    "prompt_mutation_set": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "summary", "file"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 200 },
        "file": { "type": "string", "minLength": 1 }
      }
    }
  }
}
