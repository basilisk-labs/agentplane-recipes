{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentplane.dev/schemas/recipe-manifest.schema.json",
  "title": "agentplane recipe manifest (v1)",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "id", "version", "name", "summary", "description", "scenarios"],
  "properties": {
    "schema_version": { "type": "string", "const": "1" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "name": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 200 },
    "description": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "compatibility": { "$ref": "#/$defs/compatibility" },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/skill" }
    },
    "agents": {
      "type": "array",
      "items": { "$ref": "#/$defs/agent" }
    },
    "tools": {
      "type": "array",
      "items": { "$ref": "#/$defs/tool" }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scenario" }
    }
  },
  "$defs": {
    "compatibility": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "min_agentplane_version": { "type": "string", "minLength": 1 },
        "manifest_api_version": { "type": "string", "minLength": 1 },
        "scenario_api_version": { "type": "string", "minLength": 1 },
        "runtime_api_version": { "type": "string", "minLength": 1 },
        "platforms": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "repo_types": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "summary", "kind", "file"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 200 },
        "kind": { "type": "string", "minLength": 1 },
        "file": { "type": "string", "minLength": 1 }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "display_name", "role", "summary", "file"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 200 },
        "skills": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "tools": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "file": { "type": "string", "minLength": 1 }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "runtime", "entrypoint", "summary"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "runtime": { "type": "string", "enum": ["node", "bash"] },
        "entrypoint": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 200 },
        "permissions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "timeout_ms": { "type": "number" },
        "cwd_policy": { "type": "string", "minLength": 1 }
      }
    },
    "run_profile": {
      "type": "object",
      "additionalProperties": true,
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "minLength": 1 },
        "sandbox": { "type": "string", "minLength": 1 },
        "network": { "type": "boolean" },
        "requires_human_approval": { "type": "boolean" },
        "writes_artifacts_to": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "expected_exit_contract": { "type": "string", "minLength": 1 }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "name",
        "summary",
        "use_when",
        "required_inputs",
        "outputs",
        "permissions",
        "artifacts",
        "agents_involved",
        "skills_used",
        "tools_used",
        "run_profile",
        "file"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 200 },
        "description": { "type": "string", "minLength": 1 },
        "use_when": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "avoid_when": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "required_inputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "permissions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "artifacts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "agents_involved": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "skills_used": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "tools_used": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "run_profile": { "$ref": "#/$defs/run_profile" },
        "file": { "type": "string", "minLength": 1 }
      }
    }
  }
}
